# Kimi / Moonshot API
KIMI_API_KEY=your_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k          # or kimi-k2 if available on your account

# App
APP_ENV=production
LOG_LEVEL=info
SECRET_KEY=change-me-to-a-random-64-char-string

# Sandbox
SANDBOX_URL=http://sandbox:8001
MAX_EXEC_TIME=30

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=agent_memory

# Agent behaviour
MAX_DEBUG_RETRIES=3
MAX_PLAN_STEPS=10
AGENT_TIMEOUT=120

# Optional: web search (uses DuckDuckGo by default, no key needed)
# SERPAPI_KEY=
